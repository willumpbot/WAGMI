# ============================================================
# nunuIRL Trading Bot - Environment Configuration
# ============================================================
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in YOUR values below (marked with <-- FILL THIS)
#   3. Start paper trading:  cd bot && python run.py paper
#
# IMPORTANT: Paper trade for at least 36 hours before going live.
# When ready for real money: change ENVIRONMENT=production
# ============================================================

# ── Mode ─────────────────────────────────────────────────────
# "paper" = simulated trades (safe, no real money)
# "production" = REAL trades on Hyperliquid (requires API keys)
ENVIRONMENT=paper

# ── Equity & Risk ────────────────────────────────────────────
# How much capital the bot manages. Set this to your actual balance.
STARTING_EQUITY=400.0

# Risk per trade as a decimal (0.02 = 2% of equity per trade)
# On $400 that's $8 max risk per trade
RISK_PER_TRADE=0.02

# Max simultaneous open positions (3 recommended for $400)
MAX_OPEN_POSITIONS=3

# ── Leverage ─────────────────────────────────────────────────
ENABLE_LEVERAGE=true
# Max leverage cap. Keep conservative on small accounts.
MAX_LEVERAGE=10.0

# ── Correlation Guard ────────────────────────────────────────
# Prevents concentrated directional exposure
MAX_SAME_DIRECTION=2
MAX_SAME_TIER=2

# ── Strategy ─────────────────────────────────────────────────
ENSEMBLE_MODE=weighted_veto
MIN_VOTES_REQUIRED=2
VETO_RATIO=1.1
# Scan interval in seconds (how often the bot checks for signals)
SCAN_INTERVAL_S=60

# ── Trailing Stop ────────────────────────────────────────────
ENABLE_TRAILING_STOP=true
TRAILING_STOP_ATR_MULT=1.5

# ── ML Learning ──────────────────────────────────────────────
ENABLE_ML=true
ML_MIN_SAMPLES=20
ML_RETRAIN_INTERVAL=10

# ── Circuit Breakers (loss protection) ───────────────────────
# Daily loss limit as decimal (0.05 = 5% of equity)
CIRCUIT_BREAKER_DAILY_LOSS_PCT=0.05
# Stop after N consecutive losses
MAX_CONSECUTIVE_LOSSES=4
# Cooldown in minutes after circuit breaker trips
CIRCUIT_BREAKER_COOLDOWN_MIN=120
# Only trades with this confidence can override circuit breaker
CB_CONF_OVERRIDE_PCT=0.95

# ── LLM Meta-Brain (Claude AI) ──────────────────────────────
# Controls how much autonomy the LLM has:
#   0 = OFF (no LLM involvement)
#   1 = ADVISORY (LLM suggests, bot ignores)
#   2 = VETO_ONLY (LLM can block bad trades) <-- START HERE
#   3 = SIZING (LLM adjusts position sizes)
#   4 = DIRECTION (LLM can flip trade direction)
#   5 = FULL (LLM has full control)
LLM_MODE=2

# Your Anthropic API key (get from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=                              # <-- FILL THIS

# LLM model to use (Haiku = cheapest, Sonnet = best value, Opus = max intelligence)
LLM_MODEL=claude-sonnet-4-5-20250929

# Usage tier (overrides individual rate limits below with smart defaults):
#   CONSERVATIVE  — Haiku only, tight throttle (~$18/mo)
#   RECOMMENDED   — Sonnet default, balanced (~$130/mo)
#   AGGRESSIVE    — Opus for critical, Sonnet for routine (~$600/mo)
#   UNLEASHED     — Full Opus everywhere (~$1,400/mo)
LLM_USAGE_TIER=RECOMMENDED

# Rate limiting for LLM calls (controls API cost)
LLM_MIN_COOLDOWN_S=20
LLM_MAX_CALLS_HOUR=30
LLM_MAX_CALLS_DAY=400

# ── Telegram Bot (REQUIRED for monitoring) ───────────────────
# Setup steps:
#   1. Open Telegram, message @BotFather
#   2. Send /newbot, follow prompts, get your bot token
#   3. Message @userinfobot to get your chat ID
#   4. Message @RawDataBot to get your user ID (for command security)
#   5. Start a chat with your new bot (send /start)
TELEGRAM_TOKEN=                                 # <-- FILL THIS (from @BotFather)
TELEGRAM_CHAT_ID=                               # <-- FILL THIS (from @userinfobot)

# YOUR Telegram user ID (number) - prevents strangers from controlling the bot
# Get this from @RawDataBot or @userinfobot (it's the numeric "Id" field)
TELEGRAM_ALLOWED_USER_ID=                       # <-- FILL THIS (e.g. 6218092459)

# ── Telegram Signal Ingestion (OPTIONAL) ─────────────────────
# Monitor external Telegram channels/groups for trading signals
# The bot parses signals like "LONG BTC 97500 SL 96000 TP 100000"
# and runs them through LLM analysis before acting on them.
#
# Can reuse the main bot token, or use a separate one:
TELEGRAM_SIGNAL_TOKEN=                          # <-- FILL THIS (or leave blank to reuse TELEGRAM_TOKEN)

# Comma-separated channel/group IDs to monitor for signals
# To get a channel ID: forward a message from the channel to @RawDataBot
TELEGRAM_SIGNAL_CHANNELS=                       # <-- FILL THIS (e.g. -1001234567890,-1009876543210)

# ── Discord (OPTIONAL) ──────────────────────────────────────
# Create webhook: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK=

# ── Data Source ──────────────────────────────────────────────
# No API keys needed! CCXT fetches from Hyperliquid (primary),
# Kraken/Bybit (fallback), CoinGecko (final fallback).
# Optional: free key from coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# ── Trade Execution ─────────────────────────────────────────
# Trade rotation: automatically exit stale positions for better ones
ENABLE_ROTATION=true
ROTATION_MIN_HOLD_S=300
ROTATION_GLOBAL_COOLDOWN_S=600
ROTATION_MAX_PER_HOUR=2
ROTATION_MAX_PER_DAY=6

# Fill price slippage guard (percent)
MAX_ENTRY_SLIPPAGE_PCT=1.5

# Time-based sizing adjustments
WEEKEND_SIZE_MULTIPLIER=0.5
LOW_LIQ_HOURS_MULTIPLIER=0.7

# ── Regime ───────────────────────────────────────────────────
HTF_HOURS=16
VERBOSE=true

# ── NunuIRL API (OPTIONAL - skip for local use) ─────────────
BASE_URL=
NUNUIRL_API_KEY=
STRATEGY_ID=multi-strategy

# ── Wave 1: Intelligence Features ────────────────────────────
# Signal flagger: cheap heuristic flags (SNIPER, ANOMALY, etc.) on every signal
ENABLE_SIGNAL_FLAGGER=true
# Signal override: bypass soft blockers for exceptionally powerful signals
ENABLE_SIGNAL_OVERRIDE=true
# Self-teaching: periodic learning cycles that build axioms/principles/hypotheses
ENABLE_SELF_TEACHING=true
# Few-shot: inject similar past trades as examples in LLM prompts
ENABLE_FEW_SHOT=true
# Multi-LLM ensemble: vote across multiple models for high-priority decisions
LLM_ENSEMBLE_ENABLED=false
# Comma-separated model:weight pairs (e.g. "opus:1.0,sonnet:0.8")
LLM_PERSONAS=

# ── Multi-Agent System ─────────────────────────────────────────
# Specialist agents (Regime, Trade, Risk, Learning, Critic) instead of monolithic LLM
# Each agent has a focused prompt and sees only the context relevant to its domain.
# Benefits: better decisions, dedicated learning, self-critique before execution.
LLM_MULTI_AGENT=false
# Per-agent model overrides (leave empty to use tier-based routing)
# Regime + Risk + Learning default to Haiku (fast, cheap)
# Trade + Critic default to Sonnet (primary decision-makers)
AGENT_REGIME_MODEL=
AGENT_TRADE_MODEL=
AGENT_RISK_MODEL=
AGENT_LEARNING_MODEL=
AGENT_CRITIC_MODEL=
# Disable specific agents (all enabled by default when multi-agent is on)
AGENT_RISK_ENABLED=true
AGENT_LEARNING_ENABLED=true
AGENT_CRITIC_ENABLED=true

# ── Wave 2: Execution Intelligence ──────────────────────────
# Signal decay: reduce confidence for signals older than this (seconds)
SIGNAL_DECAY_SECONDS=180
# Regime filter: disable strategies with <35% win rate in current regime
ENABLE_REGIME_STRATEGY_FILTER=true
# Dynamic TP: scale TP1 close % based on momentum and overshoot
DYNAMIC_TP_SCALING=true
# Liquidity guard: reject entries in dead markets, reduce size in extreme funding
ENABLE_LIQUIDITY_GUARD=true
# Smart orders: use limit orders for lower-urgency entries (experimental)
ENABLE_SMART_ORDERS=false

# ── Advanced / Rarely Changed ────────────────────────────────
# Risk profile: conservative, normal, aggressive
# RISK_PROFILE=normal
# RL learning buffer size
# RL_BUFFER_SIZE=10000
# Enable RL policy (experimental)
# ENABLE_RL_POLICY=false
# Kill switch file path
# KILL_SWITCH_FILE=data/.kill_switch
