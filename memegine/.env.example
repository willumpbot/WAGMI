# Anthropic API key for Claude (the director's brain).
# Not required if you only use the tool via Claude Code session.
ANTHROPIC_API_KEY=

# Model selection. Opus for ideation, Sonnet for utility work.
MEMEGINE_IDEATION_MODEL=claude-opus-4-7
MEMEGINE_UTILITY_MODEL=claude-sonnet-4-6

# Paths (default to repo-local data/)
MEMEGINE_DATA_DIR=./data
MEMEGINE_CODEX_PATH=./data/codex/style.md
MEMEGINE_REFERENCES_DIR=./data/references
MEMEGINE_OUTPUTS_DIR=./data/outputs
MEMEGINE_LOGS_DIR=./data/logs
