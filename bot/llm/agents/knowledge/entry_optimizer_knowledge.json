{
  "metadata": {
    "agent": "Entry Optimizer",
    "purpose": "Discover and optimize entry timing strategies",
    "last_updated": "2026-03-20",
    "version": "1.0"
  },
  "entry_methods": {
    "market_now": {
      "name": "Market Order (Immediate Entry)",
      "description": "Enter at current market price immediately",
      "pros": [
        "No slippage from waiting",
        "Captures fast moves",
        "Good for momentum entries"
      ],
      "cons": [
        "Higher risk of fakeouts",
        "May chase into resistance",
        "Lower overall win rate (typically -2-3%)"
      ],
      "best_for": [
        "Strong momentum setups (3+ std dev move)",
        "Breakouts with volume",
        "Early trend confirmation"
      ],
      "worst_for": [
        "Ranging markets",
        "Weak signals",
        "Against major trend"
      ],
      "sample_wr": 0.50,
      "notes": "Use only when extremely confident"
    },
    "wait_for_pullback": {
      "name": "Wait for Pullback/Retracement",
      "description": "Enter on pullback to support level or moving average",
      "pros": [
        "Better entry price",
        "+5-8% WR improvement over market now",
        "Filters out fakeouts",
        "Aligns with support levels"
      ],
      "cons": [
        "May miss fast moves",
        "Requires patience",
        "Setup disappears if doesn't pullback"
      ],
      "best_for": [
        "Trending markets",
        "regime_trend strategy",
        "Strong directional bias"
      ],
      "worst_for": [
        "Very fast trending moves (already too far)",
        "Choppy/ranging markets"
      ],
      "pullback_targets": [
        "EMA20 (short-term support)",
        "SMA50 (medium-term support)",
        "SMA200 (long-term support)",
        "Previous day close",
        "Fibonacci 0.382 retracement",
        "Pivot points (support)"
      ],
      "sample_wr": 0.58,
      "notes": "Best documented entry method for improving accuracy"
    },
    "reclaim_level": {
      "name": "Reclaim Level Entry",
      "description": "Enter once price reclaims a key technical level",
      "pros": [
        "Strong confirmation of direction",
        "High win rate (58-65%)",
        "Reduces false breakouts",
        "Clear entry signal"
      ],
      "cons": [
        "May miss initial move",
        "Requires identification of key levels",
        "Sometimes late to entry"
      ],
      "best_for": [
        "Breakouts above resistance",
        "Support holds",
        "Double bottom/top patterns"
      ],
      "levels_to_reclaim": [
        "Previous resistance (now support)",
        "Daily high",
        "Psychological round numbers",
        "Volume nodes",
        "Bollinger Band level"
      ],
      "sample_wr": 0.62,
      "notes": "Often best for counter-trend recoveries"
    },
    "ema_cross": {
      "name": "EMA Crossover Entry",
      "description": "Enter when price crosses above/below EMA",
      "pros": [
        "Mechanical, removes emotion",
        "Good for trending markets",
        "Works across timeframes"
      ],
      "cons": [
        "Whipsaw in choppy markets",
        "Lagging indicator",
        "Late to entry in fast moves"
      ],
      "timeframes": [20, 50, 200],
      "sample_wr": 0.52,
      "notes": "Use in strong trends only"
    },
    "rsi_divergence": {
      "name": "RSI Divergence Entry",
      "description": "Enter on RSI divergence from price",
      "pros": [
        "Catches reversals well",
        "High accuracy (58-65%)"
      ],
      "cons": [
        "Requires analysis",
        "Not always clear",
        "Can fail in strong trends"
      ],
      "sample_wr": 0.61,
      "notes": "Bullish div = oversold + higher lows"
    }
  },
  "regime_specific_rules": {
    "trend": {
      "recommended_entry": "wait_for_pullback",
      "wr_improvement": "+6-8%",
      "reason": "Pullbacks are natural in trends, high probability continuation",
      "timing": "On pullback to EMA20 or SMA50",
      "examples": [
        "BTC in uptrend: wait for pullback to EMA20, then buy",
        "ETH breaking 5-day high: wait for small pullback, enter"
      ]
    },
    "range": {
      "recommended_entry": "market_now",
      "wr_improvement": "+2-3%",
      "reason": "Ranges have clear support/resistance, immediate entry at bounce points",
      "timing": "At support level, not after",
      "examples": [
        "SOL trading 95-105: enter market at support (95)",
        "BTC in weekly range: enter at range bottom"
      ]
    },
    "panic": {
      "recommended_entry": "reclaim_level",
      "wr_improvement": "+4-5%",
      "reason": "Panic involves fakeout bounces, wait for real reclaim",
      "timing": "Only on reclaim above previous low",
      "examples": [
        "Crash to low: wait for reclaim of crash low",
        "Liquidation cascade: reclaim level shows exhaustion"
      ]
    },
    "high_volatility": {
      "recommended_entry": "wait_for_pullback",
      "wr_improvement": "+3-4%",
      "reason": "Volatility creates whipsaws, pullbacks filter them",
      "timing": "On pullback, then confirm with volume"
    },
    "low_liquidity": {
      "recommended_entry": "skip",
      "wr_improvement": "avoid",
      "reason": "Too much slippage and manipulation risk",
      "timing": "Don't trade",
      "examples": ["Alt coins with <$100M volume", "Illiquid pairs"]
    }
  },
  "symbol_specific_patterns": {
    "BTC": {
