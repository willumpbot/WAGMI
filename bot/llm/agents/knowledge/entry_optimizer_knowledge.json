    },
    "major_alts": {
      "best_entry": "wait_for_pullback",
      "pullback_target": "EMA20",
      "success_rate": 0.59,
      "notes": "Similar to ETH, follow BTC with lag"
    }
  },
  "time_of_day_patterns": {
    "asian_hours": {
      "utc_range": "00:00-08:00",
      "characteristics": "Lower volume, wider spreads, directional moves",
      "entry_preference": "wait_for_pullback",
      "success_rate": 0.61,
      "notes": "Less algos, more retail trading"
    },
    "london_open": {
      "utc_range": "08:00-11:00",
      "characteristics": "Volume spike, trend acceleration",
      "entry_preference": "market_now or reclaim",
      "success_rate": 0.63,
      "notes": "Most liquid hours"
    },
    "us_open": {
      "utc_range": "13:00-20:00",
      "characteristics": "Volume spike, volatility",
      "entry_preference": "wait_for_pullback",
      "success_rate": 0.64,
      "notes": "Largest volume, risk = volatility"
    },
    "overlap_times": {
      "utc_range": "08:00-11:00, 13:00-16:00",
      "characteristics": "Highest volume, fast moves",
      "entry_preference": "market_now",
      "success_rate": 0.65,
      "notes": "Best entry execution"
    }
  },
  "fakeout_patterns": {
    "whipsaw_above_resistance": {
      "pattern": "Price breaks above resistance, then immediately reverses",
      "detection": "Candle closes above resistance, next candle inside/below",
      "how_to_avoid": "Wait for pullback back to resistance, then re-entry on reclaim",
      "improvement_with_pullback_wait": "+7-10%"
    },
    "false_breakout_high_volume": {
      "pattern": "High volume spike, breakout, then reversal",
      "detection": "Volume >2x average, but no follow-through",
      "how_to_avoid": "Wait for 2nd breakout confirmation",
      "improvement_with_pullback_wait": "+5-8%"
    },
    "crash_relief_rally": {
      "pattern": "Crash bottom, relief rally, then continues down",
      "detection": "Fast rally after crash, but lower highs",
      "how_to_avoid": "Only long on reclaim of low, not on initial bounce",
      "improvement_with_reclaim_wait": "+6-9%"
    }
  },
