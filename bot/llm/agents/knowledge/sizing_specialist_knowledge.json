  "kelly_criterion_framework": {
    "theory": {
      "description": "Kelly Criterion: f* = (bp - q) / b, where f* is % of capital to risk, b is profit ratio, p is win rate, q is loss rate",
      "formula": "f* = (bp - q) / b = (p * win_size - (1-p) * loss_size) / win_size",
      "purpose": "Optimal sizing that maximizes long-term geometric growth",
      "warning": "Full Kelly can create drawdowns of 10-15%; most use fractional Kelly (0.25-0.5)"
    },
    "fractional_kelly_options": {
      "quarter_kelly": {
        "fraction": 0.25,
        "description": "Very conservative, smooth equity curve",
        "typical_max_dd": "5-8%",
        "growth_rate": "Slow but steady",
        "use_case": "Large accounts, risk-averse traders"
      },
      "half_kelly": {
        "fraction": 0.5,
        "description": "Balanced aggression and drawdown",
        "typical_max_dd": "10-15%",
        "growth_rate": "Strong, sustainable",
        "use_case": "Most professional traders, recommended default"
      },
      "three_quarter_kelly": {
        "fraction": 0.75,
        "description": "More aggressive than half",
        "typical_max_dd": "15-22%",
        "growth_rate": "Very strong but volatile",
        "use_case": "Experienced traders with high win rates"
      },
      "full_kelly": {
        "fraction": 1.0,
        "description": "Maximal growth but very volatile",
        "typical_max_dd": "20-30%+",
        "growth_rate": "Explosive but risky",
        "use_case": "Only if win rate > 60% and risk tolerance very high"
      }
    },
    "kelly_examples": {
      "example_1": {
        "win_rate": 0.55,
        "avg_win": "$150",
        "avg_loss": "-$100",
        "risk_reward_ratio": 1.5,
        "calculations": {
          "q": 0.45,
          "p": 0.55,
          "b": 1.5,
          "full_kelly_fraction": "((0.55 * 1.5) - 0.45) / 1.5 = 0.2667",
          "quarter_kelly": 0.0667,
          "half_kelly": 0.1333,
          "three_quarter_kelly": 0.2000,
          "full_kelly": 0.2667
        },
        "position_sizing_interpretation": {
          "quarter_kelly_percent": "Risk 0.67% of capital per trade",
          "half_kelly_percent": "Risk 1.33% of capital per trade",
          "three_quarter_kelly_percent": "Risk 2.00% of capital per trade",
          "full_kelly_percent": "Risk 2.67% of capital per trade"
        }
      },
      "example_2": {
        "win_rate": 0.60,
        "avg_win": "$200",
        "avg_loss": "-$100",
        "risk_reward_ratio": 2.0,
        "calculations": {
          "q": 0.40,
          "p": 0.60,
          "b": 2.0,
          "full_kelly_fraction": "((0.60 * 2.0) - 0.40) / 2.0 = 0.40",
          "quarter_kelly": 0.10,
          "half_kelly": 0.20,
          "three_quarter_kelly": 0.30,
          "full_kelly": 0.40
        },
        "position_sizing_interpretation": {
          "quarter_kelly_percent": "Risk 1% of capital per trade",
          "half_kelly_percent": "Risk 2% of capital per trade",
          "three_quarter_kelly_percent": "Risk 3% of capital per trade",
          "full_kelly_percent": "Risk 4% of capital per trade"
        }
      },
      "example_3": {
        "win_rate": 0.65,
        "avg_win": "$300",
        "avg_loss": "-$100",
        "risk_reward_ratio": 3.0,
        "calculations": {
          "q": 0.35,
          "p": 0.65,
          "b": 3.0,
          "full_kelly_fraction": "((0.65 * 3.0) - 0.35) / 3.0 = 0.55",
          "quarter_kelly": 0.1375,
          "half_kelly": 0.275,
          "three_quarter_kelly": 0.4125,
          "full_kelly": 0.55
        },
        "position_sizing_interpretation": {
          "quarter_kelly_percent": "Risk 1.375% of capital per trade",
          "half_kelly_percent": "Risk 2.75% of capital per trade",
          "three_quarter_kelly_percent": "Risk 4.125% of capital per trade",
          "full_kelly_percent": "Risk 5.5% of capital per trade"
        }
      }
    }
  },
