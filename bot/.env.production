# ============================================================
# nunuIRL PRODUCTION CONFIG - Small Account ($400)
# ============================================================
# Copy to .env and fill in your secrets.
# PAPER TRADE FIRST with ENVIRONMENT=paper for 2+ weeks.
# When ready: ENVIRONMENT=production
# ============================================================

# ── Mode ─────────────────────────────────────────────────────
# Start with paper. Switch to production ONLY after 2 weeks + 100 trades.
ENVIRONMENT=paper

# ── Equity & Risk (tuned for $400 account) ───────────────────
STARTING_EQUITY=400.0
RISK_PER_TRADE=0.02
# 2% of $400 = $8 risk per trade.
# At 3x leverage with a 1.5% stop, that's ~$40 notional.
# If you add more capital, adjust STARTING_EQUITY accordingly.

MAX_OPEN_POSITIONS=3
# With $400, max 3 positions. Prevents over-exposure.
# Each position risks $8 max, so worst case 3 simultaneous losses = $24 = 6%.

# ── Leverage (CONSERVATIVE for small account) ────────────────
ENABLE_LEVERAGE=true
MAX_LEVERAGE=10.0
# Capped at 10x. Per-symbol caps in symbol_precision.json still apply.
# BTC/ETH can go higher but we don't want 25x on $400.

# ── Correlation Guard (NEW) ──────────────────────────────────
MAX_SAME_DIRECTION=2
# Max 2 positions in the same direction (both LONG or both SHORT).
# Prevents getting wiped if BTC dumps and all your longs die together.

MAX_SAME_TIER=2
# Max 2 positions from the same risk tier (low/medium/high).
# Prevents 3 meme coin positions open simultaneously.

# ── Strategy ─────────────────────────────────────────────────
ENSEMBLE_MODE=weighted_veto
MIN_VOTES_REQUIRED=2
VETO_RATIO=1.1
SCAN_INTERVAL_S=60
# 60s scan interval (not 30s). Reduces API calls, less noise.
# You're running 24/7 on a VPS, no rush.

# ── Trailing Stop ────────────────────────────────────────────
ENABLE_TRAILING_STOP=true
TRAILING_STOP_ATR_MULT=1.5

# ── ML Learning ──────────────────────────────────────────────
ENABLE_ML=true
ML_MIN_SAMPLES=20
ML_RETRAIN_INTERVAL=10

# ── Circuit Breakers (TIGHT for small account) ───────────────
CIRCUIT_BREAKER_DAILY_LOSS_PCT=0.05
# 5% of $400 = $20 daily loss limit. Stops trading for the day.
MAX_CONSECUTIVE_LOSSES=4
# 4 losses in a row = stop. On $400, 4 losses = $32 = 8% drawdown.
CIRCUIT_BREAKER_COOLDOWN_MIN=120
# 2 hour cooldown after circuit breaker. Give the market time.
CB_CONF_OVERRIDE_PCT=0.95
# Only 95%+ confidence trades can override circuit breaker.

# ── LLM Meta-Brain ──────────────────────────────────────────
LLM_MODE=2
# 0=OFF, 1=ADVISORY, 2=VETO_ONLY, 3=SIZING, 4=DIRECTION, 5=FULL
# Start with VETO_ONLY (2): LLM can block bad trades before entry.
# Proceed/flat only, no sizing changes, no direction flips.
# All decisions logged for dual-world comparison (baseline vs LLM).
# Switch to SIZING (3) after 100+ vetoes with measured accuracy.

ANTHROPIC_API_KEY=
# Get from: https://console.anthropic.com/settings/keys
# Uses Claude Haiku by default (~$11/month at 5 calls/hour)

LLM_MODEL=claude-haiku-4-5-20251001
# Cheapest model. $1/M input, $5/M output.
# Do NOT use Sonnet/Opus until the bot is profitable.

LLM_MIN_COOLDOWN_S=30
LLM_MAX_CALLS_HOUR=15
# 15/hr (not 20) to keep costs under $10/month
LLM_MAX_CALLS_DAY=150

# ── Alerts (REQUIRED - this is your monitoring) ─────────────
# Telegram setup:
#   1. Message @BotFather on Telegram, send /newbot
#   2. Name it "nunuIRL Bot" or whatever
#   3. Copy the token below
#   4. Message @userinfobot to get your chat ID
#   5. Message @RawDataBot for your user ID (for command security)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_ID=0
# Set to YOUR Telegram user ID (number). This prevents random
# people from controlling your bot if they find the bot username.

# Discord (optional, Telegram is enough)
DISCORD_WEBHOOK=

# ── Data Source ──────────────────────────────────────────────
# No API keys needed! CCXT fetches from Hyperliquid (primary),
# Kraken/Bybit (fallback), CoinGecko (final fallback).
COINGECKO_API_KEY=
# Optional: free key from coingecko.com/en/api/pricing for higher rate limits

# ── Regime ───────────────────────────────────────────────────
HTF_HOURS=16
VERBOSE=true

# ── NunuIRL API (skip for now) ──────────────────────────────
BASE_URL=
NUNUIRL_API_KEY=
STRATEGY_ID=multi-strategy
