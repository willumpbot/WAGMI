# Environment: "paper" (default) or "production"
ENVIRONMENT=paper

# Equity & Risk
STARTING_EQUITY=10000.0
RISK_PER_TRADE=0.015
MAX_OPEN_POSITIONS=3

# Strategy
ENSEMBLE_MODE=voting
MIN_VOTES_REQUIRED=2
SCAN_INTERVAL_S=60

# Leverage (minimum 2x, no spot trading)
ENABLE_LEVERAGE=true
MAX_LEVERAGE=25.0

# Trailing Stop
ENABLE_TRAILING_STOP=true
TRAILING_STOP_ATR_MULT=1.5

# ML Learning
ENABLE_ML=true
ML_MIN_SAMPLES=20
ML_RETRAIN_INTERVAL=10

# Circuit Breakers
CIRCUIT_BREAKER_DAILY_LOSS_PCT=0.05
MAX_CONSECUTIVE_LOSSES=5
CIRCUIT_BREAKER_COOLDOWN_MIN=60

# Alerts - Discord (create webhook: Server Settings > Integrations > Webhooks)
DISCORD_WEBHOOK=
# DISCORD_PRIORITY_WEBHOOK=

# Alerts - Telegram (create bot via @BotFather, get chat ID via @userinfobot)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# NunuIRL API (optional - for dashboard integration)
BASE_URL=http://api:8000
NUNUIRL_API_KEY=
STRATEGY_ID=multi-strategy

# Regime timeframe
HTF_HOURS=16
VERBOSE=true
