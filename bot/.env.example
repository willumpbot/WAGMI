# Environment: "paper" (default) or "production"
ENVIRONMENT=paper

# Data source: CCXT pulls real OHLCV from Kraken (BTC,SOL) + Hyperliquid (HYPE)
# No API keys needed! Auto-fallback if an exchange is geo-blocked.
# CoinGecko is the final fallback if all exchanges fail.
# Optional: CoinGecko API key for fallback (free at coingecko.com/en/api/pricing)
COINGECKO_API_KEY=

# Equity & Risk
STARTING_EQUITY=10000.0
RISK_PER_TRADE=0.015
MAX_OPEN_POSITIONS=3

# Strategy
ENSEMBLE_MODE=weighted_veto
MIN_VOTES_REQUIRED=2
VETO_RATIO=1.1
SCAN_INTERVAL_S=30

# Leverage (minimum 2x, no spot trading)
ENABLE_LEVERAGE=true
MAX_LEVERAGE=25.0

# Trailing Stop
ENABLE_TRAILING_STOP=true
TRAILING_STOP_ATR_MULT=1.5

# ML Learning
ENABLE_ML=true
ML_MIN_SAMPLES=20
ML_RETRAIN_INTERVAL=10

# Circuit Breakers
CIRCUIT_BREAKER_DAILY_LOSS_PCT=0.05
MAX_CONSECUTIVE_LOSSES=5
CIRCUIT_BREAKER_COOLDOWN_MIN=60

# Alerts - Discord (create webhook: Server Settings > Integrations > Webhooks)
DISCORD_WEBHOOK=
# DISCORD_PRIORITY_WEBHOOK=

# Alerts - Telegram (create bot via @BotFather, get chat ID via @userinfobot)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# NunuIRL API (optional - for dashboard integration)
BASE_URL=http://api:8000
NUNUIRL_API_KEY=
STRATEGY_ID=multi-strategy

# Regime timeframe
HTF_HOURS=16
VERBOSE=true

# ── Wave 3: Portfolio Risk ────────────────────────────────────────
# Enable portfolio-level correlation and risk budgeting
ENABLE_PORTFOLIO_RISK=true
# Maximum total portfolio risk as percentage of equity
MAX_PORTFOLIO_RISK_PCT=6.0
# Detect BTC/ETH cascade sell-offs and pause alt entries
ENABLE_CASCADE_SIGNALS=true

# ── Wave 3: Analytics ─────────────────────────────────────────────
# A/B testing framework for strategy parameter experiments
ENABLE_AB_TESTING=false
# Counterfactual learning: track what-if outcomes for vetoed trades
ENABLE_COUNTERFACTUAL=true
# Meta-learning: auto-analyze decision patterns and generate strategy ideas
ENABLE_META_LEARNING=true
# Attribution analysis: decompose PnL by factor (strategy, regime, time, etc.)
ENABLE_ATTRIBUTION=true

# ── Wave 4: Dashboard ────────────────────────────────────────────
# Enable the built-in web dashboard (http.server, zero deps)
ENABLE_DASHBOARD=true
# Port for the dashboard HTTP server
DASHBOARD_PORT=8080

# ── Wave 4: Chop Detection ──────────────────────────────────────
# ADX threshold below which market is considered choppy (0-100)
CHOP_THRESHOLD=25.0
# Enable chop detector to suppress signals in ranging markets
ENABLE_CHOP_DETECTOR=true

# ── Wave 4: Position Hold Limits ─────────────────────────────────
# Maximum hours a position can be held before forced action
MAX_HOLD_HOURS=72
# Action when hold limit is reached: "close" or "alert"
HOLD_LIMIT_ACTION=alert

# ── Dual Wallet System ──────────────────────────────────────────
# Enable A/B wallet architecture (conservative + aggressive)
DUAL_WALLET_ENABLED=false
# Equity split (must sum to 1.0)
WALLET_A_EQUITY_PCT=0.5
WALLET_B_EQUITY_PCT=0.5
# Wallet A overrides (conservative: anticipatory only, Half-Kelly)
WALLET_A_MAX_LEVERAGE=3.9
WALLET_A_MIN_RR=2.5
WALLET_A_MIN_SCORECARD=70
WALLET_A_RISK_PER_TRADE=0.0035
WALLET_A_MAX_POSITIONS=3
# Wallet B overrides (aggressive: all sources, conviction-tiered)
WALLET_B_MAX_LEVERAGE=20.0
WALLET_B_MIN_RR=1.2
WALLET_B_MIN_SCORECARD=50
WALLET_B_RISK_PER_TRADE=0.008
WALLET_B_MAX_POSITIONS=6

# ── LLM Meta-Brain ──────────────────────────────────────────────
# Smart model routing tier: CONSERVATIVE, RECOMMENDED, AGGRESSIVE, UNLEASHED
LLM_USAGE_TIER=AGGRESSIVE
# Autonomy level 0-5 (0=OFF, 1=ADVISORY, 2=VETO_ONLY, 3=SIZING, 4=DIRECTION, 5=FULL)
LLM_MODE=2
# Enable multi-agent specialist pipeline (Regime→Trade→Risk→Critic→Learning)
LLM_MULTI_AGENT=true
# Roadmap enforcement caps LLM_MODE to current phase max. Disable once past phase 1.
ROADMAP_ENFORCE=false

# ── X/Twitter Social Module ─────────────────────────────────────
# Get keys at: https://developer.x.com (Free tier = 1500 tweets/month)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=
# Timezone offset from UTC for posting schedule (EST = -4, PST = -7, etc.)
X_TIMEZONE_OFFSET=-4
